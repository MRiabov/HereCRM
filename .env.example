OPENROUTER_API_KEY=your_key_here
WHATSAPP_APP_SECRET=your_secret_here
OPENROUTER_MODEL=google/gemini-3-flash-preview

# OpenRouteService (for routing optimization)
OPENROUTESERVICE_API_KEY=your_ors_api_key_here

# S3 Storage (Backblaze B2 compatible)
S3_ENDPOINT_URL=https://s3.us-east-1.backblazeb2.com
S3_ACCESS_KEY_ID=your_id_here
S3_SECRET_ACCESS_KEY=your_secret_here
S3_BUCKET_NAME=herecrm-invoices
S3_REGION_NAME=us-east-1
STRIPE_SECRET_KEY=your_stripe_secret_key_here
