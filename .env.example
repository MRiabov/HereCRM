WHATSAPP_PHONE_NUMBER_ID=your_id_here
WHATSAPP_ACCESS_TOKEN=your_token_here
WHATSAPP_VERIFY_TOKEN=blue_cat_123
WHATSAPP_API_VERSION=v18.0
WABA_ID=your_waba_id_here

OPENROUTER_API_KEY=your_key_here
OPENROUTER_MODEL=google/gemini-3-flash-preview

# Twilio Settings (optional fallback for SMS)
TWILIO_ACCOUNT_SID=your_sid_here
TWILIO_AUTH_TOKEN=your_token_here
TWILIO_PHONE_NUMBER=your_number_here

# TextGrid Settings (default for SMS if configured)
TEXTGRID_ACCOUNT_SID=your_sid_here
TEXTGRID_AUTH_TOKEN=your_token_here
TEXTGRID_PHONE_NUMBER=your_number_here

# Postmark Settings (for inbound email)
POSTMARK_SERVER_TOKEN=your_token_here
FROM_EMAIL_ADDRESS=noreply@yourdomain.com

# OpenRouteService (for routing optimization and geocoding)
OPENROUTESERVICE_API_KEY=your_ors_api_key_here

# S3 Storage (Backblaze B2 compatible)
S3_ENDPOINT_URL=https://s3.us-east-1.backblazeb2.com
S3_ACCESS_KEY_ID=your_id_here
S3_SECRET_ACCESS_KEY=your_secret_here
S3_BUCKET_NAME=herecrm-invoices
S3_REGION_NAME=us-east-1

STRIPE_SECRET_KEY=your_stripe_secret_key_here

# Security
SECRET_KEY=dev_secret_key_change_me_in_production
GENERIC_WEBHOOK_SECRET=your_webhook_secret_here
